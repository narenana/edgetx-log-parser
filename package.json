{
  "name": "edgetx-log-parser",
  "version": "5.0.0",
  "description": "EdgeTX flight log visualizer for RC aircraft",
  "license": "GPL-3.0-or-later",
  "main": "electron/main.js",
  "author": "narenana",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:web": "vite",
    "build": "cross-env VITE_BUILD_TARGET=web vite build",
    "build:desktop": "cross-env VITE_BUILD_TARGET=desktop vite build",
    "preview": "vite preview",
    "dist": "npm run build:desktop && electron-builder"
  },
  "build": {
    "appId": "com.narenana.edgetx-log-parser",
    "productName": "RC Log Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "generateUpdatesFilesForAllChannels": false,
      "forceCodeSigning": false
    },
    "generateUpdatesFilesForAllChannels": false,
    "publish": null,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "blackbox-parser": "file:./vendor/blackbox-parser",
    "cesium": "^1.140.0",
    "chart.js": "^4.4.2",
    "leaflet": "^1.9.4",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "three": "^0.184.0",
    "vite-plugin-cesium": "^1.2.23"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-reload": "^2.0.0-alpha.1",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wait-on": "^8.0.0"
  }
}
